#!/usr/bin/env bash
# Single source of truth for the pre-commit gate: run the same battery CI
# runs (see warren-008a / pl-da5b). Diverging from `check:all` here would
# recreate the gate-drift that warren-5797 was opened to kill. If a check
# is too slow for the hook, fix the check — don't carve out a subset.
set -euo pipefail
exec bun run check:all
