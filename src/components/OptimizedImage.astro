---
// src/components/OptimizedImage.astro
// Serves responsive images from the pre-optimized /_optimized/ directory

interface Props {
  src: string;
  alt?: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  sizes?: string;
  widths?: number[];
}

const {
  src,
  alt = '',
  class: className = '',
  loading = 'lazy',
  sizes = '100vw',
  widths = [400, 800, 1200],
} = Astro.props;

// Generate hash matching optimize-images.ts DJB2 algorithm
function djb2Hash(str: string): string {
  let hash = 5381;
  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) + hash) ^ str.charCodeAt(i);
  }
  return Math.abs(hash).toString(16).slice(0, 8);
}

// Parse the source path
const srcPath = src.startsWith('/') ? src : `/${src}`;
const hash = djb2Hash(srcPath);
const baseName = srcPath.split('/').pop()?.replace(/\.[^.]+$/, '') || '';

// Build srcset from optimized images
const srcset = widths
  .map((w) => `/_optimized/${baseName}-${hash}-${w}.webp ${w}w`)
  .join(', ');

// Use largest optimized image as fallback src
const fallbackSrc = `/_optimized/${baseName}-${hash}-${widths[widths.length - 1]}.webp`;
---

<img
  src={fallbackSrc}
  srcset={srcset}
  sizes={sizes}
  alt={alt}
  class={className}
  loading={loading}
  decoding="async"
/>
