---
import { tinaField } from '@tinacms/astro/tina-field';

// Home Sections
import HomeHero from './sections/home/Hero.astro';
import HomeAbout from './sections/home/About.astro';

// About Sections
import AboutHero from './sections/about/Hero.astro';
import BehindName from './sections/about/BehindName.astro';
import Bio from './sections/about/Bio.astro';
import Awards from './sections/about/Awards.astro';
import Award from './sections/about/Award.astro';
import Mission from './sections/about/Mission.astro';

// Services Sections
import ServicesHero from './sections/services/Hero.astro';
import ServicesIntro from './sections/services/Intro.astro';
import ServiceGroups from './sections/services/Services.astro';
import Service from './sections/services/Service.astro';
import FAQ from './sections/services/FAQs.astro';
import FAQItem from './sections/services/FAQ.astro';
import WorkProcess from './sections/services/WorkProcess.astro';

// Contact Sections
import ContactFormBlock from './sections/contact/ContactBlock.astro';

// Editorial Sections
import EditorialHero from './sections/editorial/Hero.astro';
import EditorialCopy from './sections/editorial/Copy.astro';
import EditorialAccordion from './sections/editorial/Accordion.astro';
import EditorialRows from './sections/editorial/Rows.astro';
import EditorialCta from './sections/editorial/Cta.astro';
import EditorialShowcase from './sections/editorial/Showcase.astro';
import EditorialMission from './sections/editorial/Mission.astro';

// Project Sections
import ProjectDetails from './sections/projects/Details.astro';
import ProjectCollaborators from './sections/projects/Collaborators.astro';

// Common
import Banner from './sections/common/Banner.astro';
import OptimizedImage from './OptimizedImage.astro';

// Type definition for our block
interface Props {
  block: any;
  index: number;
  parentData: any;
}

const { block, index, parentData } = Astro.props;
let template = block._template;

if (!template && block.__typename) {
  const match = block.__typename.match(/Blocks(.*)$/);
  if (match) {
    const pascal = match[1];
    template = pascal.charAt(0).toLowerCase() + pascal.slice(1);
  }
}

// Helper to normalize image paths for optimization
function normalizeTinaImage(src?: string | null) {
  if (!src) return '';
  try {
    const url = new URL(src);
    if (url.hostname === 'assets.tina.io') {
      return `/images${url.pathname.replace(/^\/[^/]+/, '')}`;
    }
  } catch {
    // Relative paths are already usable by the local image optimizer.
  }
  return src;
}

---

<div data-tina-field={tinaField(parentData.blocks, index)}>
  {template === 'homeHero' && <HomeHero {...block} />}
  {template === 'homeAbout' && <HomeAbout {...block} cta={block.ctaText} />}
  
  {template === 'aboutHero' && <AboutHero title={block.title} />}
  {template === 'behindName' && (
    <BehindName
      title={block.title}
      p1={block.p1}
      p2={block.p2}
      footnote={block.footnote}
    />
  )}
  {template === 'bannerImage' && <Banner src={normalizeTinaImage(block.image)} alt={block.alt || ''} />}
  {template === 'bio' && (
    <Bio
      title={block.title}
      image={normalizeTinaImage(block.image)}
      paragraphs={block.paragraphs}
    />
  )}
  {template === 'awards' && (
    <Awards {...block}>
      {block.items && block.items.map((item: any) => (
        <Award {...item} />
      ))}
    </Awards>
  )}
  {template === 'mission' && (
    <Mission
      title={block.title}
      p1={block.p1}
      p2={block.p2}
      quote={block.quote}
    />
  )}

  {template === 'servicesHero' && <ServicesHero title={block.title} />}
  {template === 'servicesIntro' && (
    <ServicesIntro
      text={block.text}
      image={normalizeTinaImage(block.image)}
    />
  )}
  {template === 'serviceGroups' && (
    <ServiceGroups>
      {block.groups && block.groups.map((group: any) => (
        <Service title={group.title} items={group.items} />
      ))}
    </ServiceGroups>
  )}
  {template === 'faq' && (
    <FAQ {...block}>
      {block.items && block.items.map((item: any) => (
        <FAQItem question={item.question} answer={item.answer} />
      ))}
    </FAQ>
  )}
  {template === 'workProcess' && (
    <WorkProcess
      title={block.title}
      p1={block.p1}
      p2={block.p2}
      image={normalizeTinaImage(block.image)}
    />
  )}

  {template === 'editorialHero' && <EditorialHero {...block} image={normalizeTinaImage(block.image)} />}
  {template === 'editorialCopy' && <EditorialCopy {...block} />}
  {template === 'editorialAccordion' && <EditorialAccordion {...block} />}
  {template === 'editorialRows' && <EditorialRows {...block} />}
  {template === 'editorialCta' && <EditorialCta {...block} />}
  {template === 'editorialShowcase' && (
    <EditorialShowcase
      {...block}
      image={normalizeTinaImage(block.image)}
      items={block.items?.map((item: any) => ({ ...item, image: normalizeTinaImage(item.image) }))}
    />
  )}
  {template === 'editorialMission' && <EditorialMission {...block} image={normalizeTinaImage(block.image)} />}

  {template === 'projectBanner' && (
    <div class="w-full aspect-video overflow-hidden">
      <OptimizedImage
        src={normalizeTinaImage(block.image)}
        alt={block.alt}
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
  )}
  {template === 'contactForm' && <ContactFormBlock {...block} />}
  {template === 'projectDetails' && <ProjectDetails {...block} />}
  {template === 'projectBrief' && (
    <section class="py-16 md:py-24 max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-6">{block.title}</h2>
      <p class="text-lg text-gray-600 mb-12">{block.text}</p>
      {block.gallery && block.gallery.images && (
        <div class={`grid gap-4 grid-cols-${block.gallery.cols || 2}`}>
          {block.gallery.images.map((img: any) => (
            <OptimizedImage src={normalizeTinaImage(img.src)} alt={img.alt} class="w-full h-auto" />
          ))}
        </div>
      )}
    </section>
  )}
  {template === 'projectConcept' && (
    <section class="py-16 md:py-24 max-w-7xl mx-auto px-4 bg-gray-50">
      <h2 class="text-3xl font-bold mb-6">{block.title}</h2>
      <p class="text-lg text-gray-600 mb-12">{block.text}</p>
      {block.gallery && block.gallery.images && (
        <div class={`grid gap-4 grid-cols-${block.gallery.cols || 2}`}>
          {block.gallery.images.map((img: any) => (
            <OptimizedImage src={normalizeTinaImage(img.src)} alt={img.alt} class="w-full h-auto" />
          ))}
        </div>
      )}
    </section>
  )}
  {template === 'projectStrategy' && (
    <section class="py-16 md:py-24 max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-6">{block.title}</h2>
      <p class="text-lg text-gray-600 mb-12">{block.text}</p>
      {block.carousel && block.carousel.map((img: any) => (
        <OptimizedImage src={normalizeTinaImage(img.src)} alt={img.alt} class="w-full h-auto mb-4" />
      ))}
      {block.gallery && block.gallery.images && (
        <div class={`grid gap-4 grid-cols-${block.gallery.cols || 2}`}>
          {block.gallery.images.map((img: any) => (
            <OptimizedImage src={normalizeTinaImage(img.src)} alt={img.alt} class="w-full h-auto" />
          ))}
        </div>
      )}
    </section>
  )}
  {template === 'projectCollaborators' && <ProjectCollaborators list={block.list} />}
  {template === 'projectFinalImage' && (
    <div class="w-full mt-16">
      <OptimizedImage src={normalizeTinaImage(block.src)} alt={block.alt} class="w-full h-auto" />
    </div>
  )}

</div>
