---
// src/components/HeadSEO.astro
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  schema?: 'LocalBusiness' | 'Article' | 'BreadcrumbList';
  breadcrumbs?: { name: string; url: string }[];
  lang?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishDate,
  schema,
  breadcrumbs,
  lang = 'es',
} = Astro.props;

const locales = ['es', 'ca', 'en'];
const localeMap: Record<string, string> = { es: 'es_ES', ca: 'ca_ES', en: 'en_US' };

// Build alternate URLs for hreflang
const pathname = Astro.url.pathname;
const pathWithoutLang = pathname.replace(/^\/(es|ca|en)/, '') || '/';
const alternateUrls = locales.map(locale => ({
  lang: locale,
  url: Astro.site ? new URL(`/${locale}${pathWithoutLang}`, Astro.site).toString() : `/${locale}${pathWithoutLang}`,
}));

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;

const ogImage = image && Astro.site ? new URL(image, Astro.site).toString() : null;

// LocalBusiness schema for homepage
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': Astro.site?.toString() || '',
  name: 'Sens*Hac',
  description: 'Interior design studio specialized in commercial, gastronomy, and entertainment spaces.',
  url: Astro.site?.toString() || '',
  telephone: '+34 661 661 426',
  email: 'ester@senshac.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Barcelona',
    addressCountry: 'ES',
  },
  founder: {
    '@type': 'Person',
    name: 'Ester Cobles',
  },
  sameAs: [
    'https://www.instagram.com/sens_hac/',
    'https://www.pinterest.com/senshac_design/',
    'https://www.linkedin.com/company/senshac/',
  ],
  priceRange: '$$',
  image: ogImage,
};

// Article schema for projects
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: ogImage,
  datePublished: publishDate?.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Ester Cobles',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Sens*Hac',
    logo: {
      '@type': 'ImageObject',
      url: Astro.site ? new URL('/logo.png', Astro.site).toString() : '',
    },
  },
};

// BreadcrumbList schema
const breadcrumbSchema = breadcrumbs
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.name,
        item: Astro.site ? new URL(item.url, Astro.site).toString() : item.url,
      })),
    }
  : null;

const getSchema = () => {
  switch (schema) {
    case 'LocalBusiness':
      return localBusinessSchema;
    case 'Article':
      return articleSchema;
    case 'BreadcrumbList':
      return breadcrumbSchema;
    default:
      return null;
  }
};

const schemaData = getSchema();
---

<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

<!-- Hreflang alternates -->
{alternateUrls.map(alt => (
  <link rel="alternate" hreflang={alt.lang} href={alt.url} />
))}
<link rel="alternate" hreflang="x-default" href={alternateUrls.find(a => a.lang === 'es')?.url} />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<meta name="author" content="Sens*Hac - Ester Cobles" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta property="og:site_name" content="Sens*Hac" />
<meta property="og:locale" content={localeMap[lang] || 'es_ES'} />
{locales.filter(l => l !== lang).map(l => (
  <meta property="og:locale:alternate" content={localeMap[l]} />
))}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- JSON-LD Structured Data -->
{schemaData && (
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
)}
