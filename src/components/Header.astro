---
// src/components/Header.astro
import { getTranslations, type Translations } from '../utils/translations';
import { getSiteConfig } from '../utils/site-config';
import { tinaField } from '@tinacms/astro';

interface Props {
  lang: string;
  headerStyle?: 'default' | 'transparent';
  translations?: Translations;
}

const { lang, headerStyle = 'default', translations: propTranslations } = Astro.props;
const currentPath = Astro.url.pathname;

const isTransparent = headerStyle === 'transparent';

const t = propTranslations ?? await getTranslations(lang);
const site = await getSiteConfig();

const navItems = [
  { href: `/${lang}/about`, label: t.nav.about, field: 'about' as const },
  { href: `/${lang}/projects`, label: t.nav.projects, field: 'projects' as const },
  { href: `/${lang}/services`, label: t.nav.services, field: 'services' as const },
  { href: `/${lang}/contact`, label: t.nav.contact, field: 'contact' as const },
];

// Use social links from site config
const socialLinks = site.socialLinks;

// Infer languages from locales config
const languages = site.locales.map((code: string) => ({
  code,
  label: code.toUpperCase(),
}));

const getLocalizedPath = (targetLang: string) => {
  return currentPath.replace(`/${lang}`, `/${targetLang}`);
};
---

<div
  x-data={`{
    menuOpen: false,
    langOpen: false,
    scrolled: false,
    isTransparent: ${isTransparent}
  }`}
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 50 })"
>
  <header
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
    data-header-style={headerStyle}
    x-bind:class="(isTransparent && !scrolled && !menuOpen) ? 'bg-transparent' : 'bg-white/95 backdrop-blur-sm border-b border-gray-100'"
  >
    <nav class="w-full px-4 md:px-8 h-20 flex items-center justify-between">
      <!-- Logo -->
      <a href={`/${lang}/`} class="flex-shrink-0">
        <img
          x-show="isTransparent && !scrolled && !menuOpen"
          src={site.branding.logoWhite}
          alt={site.company.name.toLowerCase()}
          class="h-8 w-auto"
          width="173"
          height="32"
        />
        <img
          x-show="!isTransparent || scrolled || menuOpen"
          src={site.branding.logo}
          alt={site.company.name.toLowerCase()}
          class="h-8 w-auto"
          width="173"
          height="32"
          x-cloak={isTransparent}
        />
      </a>

      <!-- Right side controls -->
      <div class="flex items-center gap-4">
        <!-- Language Dropdown -->
        <div class="relative" x-on:click.away="langOpen = false">
          <button
            type="button"
            class="flex items-center gap-1 text-sm uppercase tracking-wider transition-colors"
            x-bind:class="(isTransparent && !scrolled && !menuOpen) ? 'text-white/80 hover:text-white' : 'text-gray-600 hover:text-black'"
            x-on:click="langOpen = !langOpen"
            aria-label="Select language"
          >
            <span>{lang.toUpperCase()}</span>
            <span class="i-lucide-chevron-down w-3 h-3 transition-transform" x-bind:class="langOpen && 'rotate-180'" />
          </button>

          <div
            class="absolute right-0 top-full mt-2 bg-white border border-gray-200 rounded shadow-lg py-1 min-w-16"
            x-show="langOpen"
            x-transition:enter="transition ease-out duration-100"
            x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100"
            x-transition:leave="transition ease-in duration-75"
            x-transition:leave-start="opacity-100 scale-100"
            x-transition:leave-end="opacity-0 scale-95"
            x-cloak
          >
            {languages.filter(l => l.code !== lang).map((l) => (
              <a
                href={getLocalizedPath(l.code)}
                class="block px-4 py-2 text-sm uppercase text-gray-600 hover:bg-gray-50 hover:text-black transition-colors"
              >
                {l.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Hamburger Menu Button -->
        <button
          type="button"
          class="p-2 transition-colors"
          x-bind:class="(isTransparent && !scrolled && !menuOpen) ? 'text-white hover:text-white/80' : 'text-gray-800 hover:text-black'"
          x-on:click="menuOpen = !menuOpen"
          aria-label="Toggle menu"
          aria-expanded="false"
          x-bind:aria-expanded="menuOpen"
        >
          <!-- Hamburger icon -->
          <span x-show="!menuOpen" class="i-lucide-menu w-6 h-6" />
          <!-- Close icon -->
          <span x-show="menuOpen" x-cloak class="i-lucide-x w-6 h-6" />
        </button>
      </div>
    </nav>
  </header>

  <!-- Backdrop for menu - outside header -->
  <div
    class="fixed inset-0 bg-black/20 z-[60]"
    x-show="menuOpen"
    x-on:click="menuOpen = false"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    x-cloak
  ></div>

  <!-- Menu Panel - Full viewport height, half width on desktop, full on mobile -->
  <div
    class="fixed inset-0 md:left-auto md:w-1/2 bg-white z-[70] overflow-y-auto"
    x-show="menuOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    x-cloak
  >
    <div class="min-h-full flex flex-col">
      <!-- Close button inside panel -->
      <div class="flex justify-end p-4 h-20 items-center">
        <button
          type="button"
          class="p-2 text-gray-600 hover:text-black transition-colors"
          x-on:click="menuOpen = false"
          aria-label="Close menu"
        >
          <span class="i-lucide-x w-6 h-6" />
        </button>
      </div>

      <!-- Main Content -->
      <div class="flex-1 px-6 py-8 md:px-12">
        <div class="grid grid-cols-2 gap-8 md:gap-12">
          <!-- Social Column -->
          <div>
            <p class="text-sm text-gray-400 uppercase tracking-wider mb-6" data-tina-field={tinaField(t.nav, 'social')}>{t.nav.social}</p>
            <div class="space-y-0">
              {socialLinks.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block py-3 text-lg md:text-xl text-black border-b border-gray-200 hover:text-gray-600 transition-colors"
                >
                  {link.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Menu Column -->
          <div>
            <p class="text-sm text-gray-400 uppercase tracking-wider mb-6" data-tina-field={tinaField(t.nav, 'menu')}>{t.nav.menu}</p>
            <div class="space-y-0">
              {navItems.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "block py-3 text-lg md:text-xl text-black border-b border-gray-200 hover:text-gray-600 transition-colors",
                    currentPath.startsWith(item.href) && "font-medium"
                  ]}
                  x-on:click="menuOpen = false"
                  data-tina-field={tinaField(t.nav, item.field)}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Section -->
      <div class="px-6 py-8 md:px-12 border-t border-gray-200 bg-gray-50 mt-auto">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <!-- Logo and Let's Talk -->
          <div>
            <img
              src={site.branding.symbol}
              alt={site.company.name.toLowerCase()}
              class="h-10 w-auto mb-4"
              width="40"
              height="40"
            />
            <p class="text-base font-bold uppercase tracking-wider text-black" data-tina-field={tinaField(t.nav, 'letsTalk')}>{t.nav.letsTalk}</p>
          </div>

          <!-- Contact Info -->
          <div class="md:text-right">
            <a
              href={`mailto:${site.contact.email}`}
              class="block text-base text-black hover:text-gray-600 transition-colors"
            >
              {site.contact.email}
            </a>
            <a
              href={`tel:${site.contact.phoneLink || site.contact.phone.replace(/\s/g, '')}`}
              class="block text-base text-black hover:text-gray-600 transition-colors"
            >
              {site.contact.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
