---
// src/components/sections/WorkProcess.astro
import OptimizedImage from '../../OptimizedImage.astro';

interface Props {
  title?: string;
  p1?: string;
  p2?: string;
  image?: string;
}

const { title, p1, p2, image } = Astro.props;
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        {title && <h2 class="text-2xl md:text-3xl font-display mb-8">{title}</h2>}
        {p1 && <p class="text-lg text-gray-600 mb-6">{p1}</p>}
        {p2 && <p class="text-lg text-gray-600">{p2}</p>}
      </div>

      {image && (
        <div class="aspect-4/3 overflow-hidden">
          <OptimizedImage src={image} alt="" class="w-full h-full object-cover" loading="lazy" sizes="(min-width: 768px) 50vw, 100vw" />
        </div>
      )}
    </div>
  </div>
</section>
