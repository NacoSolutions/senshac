---
// src/components/sections/HeroServices.astro
interface Props {
  title: string;
  symbolImage?: string;
}

const { title, symbolImage } = Astro.props;
---

<section class="py-24 md:py-32 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 text-center">
    {symbolImage && (
      <img
        src={symbolImage}
        alt=""
        class="w-24 h-24 mx-auto mb-8"
        loading="eager"
      />
    )}
    <h1 class="text-4xl md:text-6xl font-display">{title}</h1>
  </div>
</section>
