---
import MediaPlaceholder from './MediaPlaceholder.astro';

interface Props {
  label?: string;
  paragraphs?: string[];
  statement?: string;
  image?: string;
  imageAlt?: string;
  placeholderLabel?: string;
}

const { label, paragraphs = [], statement, image, imageAlt, placeholderLabel } = Astro.props;
---

<section class="editorial-section editorial-mission">
  <div class="editorial-shell editorial-mission__grid">
    <h1 class="editorial-eyebrow">{label}</h1>
    <div class="editorial-mission__copy">
      {paragraphs.map((paragraph) => <p class="editorial-body">{paragraph}</p>)}
    </div>
  </div>
</section>

<section class="editorial-section editorial-mission__statement">
  <div class="editorial-shell">
    <h2 class="editorial-display">{statement}</h2>
    <MediaPlaceholder image={image} alt={imageAlt} label={placeholderLabel} aspect="wide" />
  </div>
</section>
