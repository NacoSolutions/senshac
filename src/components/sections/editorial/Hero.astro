---
import MediaPlaceholder from "./MediaPlaceholder.astro";
import RichText from "./RichText.astro";

interface Props {
	title?: string;
	intro?: any;
	ctaText?: string;
	ctaLink?: string;
	mediaId?: string;
	imageAlt?: string;
	mediaType?: "image" | "video";
	placeholderLabel?: string;
	objectFit?: "cover" | "contain";
}

const {
	title,
	intro,
	ctaText,
	ctaLink,
	mediaId,
	imageAlt,
	mediaType = "image",
	placeholderLabel,
	objectFit = "cover",
} = Astro.props;
---

<section class="editorial-section min-h-auto text-inherit">
  <div class="editorial-shell grid gap-[clamp(2rem,6vw,6rem)]">
    <MediaPlaceholder
      mediaId={mediaId}
      alt={imageAlt}
      kind={mediaType || 'image'}
      label={placeholderLabel}
      aspect="wide"
      objectFit={objectFit}
      eager
    />
    <div class="flex flex-col justify-between">
      <h2 class="editorial-display">{title}</h2>
      {intro && (
        <div class="editorial-lede my-auto">
          <RichText content={intro} />
        </div>
      )}
      {ctaText && ctaLink && <a class="editorial-link mt-0" href={ctaLink}>{ctaText}</a>}
    </div>
  </div>
</section>
