---
import { getCollection } from "astro:content";
import R2Picture from "../../R2Picture.astro";
import MediaPlaceholder from "./MediaPlaceholder.astro";

interface Item {
	title?: string;
	link?: string;
	mediaId?: string;
	imageAlt?: string;
	placeholderLabel?: string;
}

interface Props {
	eyebrow?: string;
	title?: string;
	ctaText?: string;
	ctaLink?: string;
	mediaType?: "image" | "video";
	mediaId?: string;
	imageAlt?: string;
	placeholderLabel?: string;
	items?: Item[] | null;
}

const {
	eyebrow,
	title,
	ctaText,
	ctaLink,
	mediaType = "image",
	mediaId,
	imageAlt,
	placeholderLabel,
	items: itemList,
} = Astro.props;
const items = itemList ?? [];

// Auto-populate from projects when no items and no media are provided
const lang = Astro.url.pathname.split("/")[1] || "es";
let projectSlides: {
	title: string;
	href: string;
	mediaId: string;
	alt: string;
}[] = [];

if (items.length === 0 && !mediaId) {
	const allProjects = await getCollection("projects", ({ id, data }) => {
		return id.startsWith(`${lang}/`) && !data.draft;
	});
	const sorted = allProjects.sort((a, b) => {
		const dateA = a.data.publishDate?.getTime() || 0;
		const dateB = b.data.publishDate?.getTime() || 0;
		return dateB - dateA;
	});
	projectSlides = sorted.map((project) => {
		const bannerBlock = project.data.blocks?.find(
			(b: any) => b._template === "projectBanner",
		);
		return {
			title: project.data.title,
			href: `/${lang}/works/${project.data.slug}`,
			mediaId: (bannerBlock?.mediaId || "")
				.replace(/^https:\/\/media\.senshac\.com\/images\//, "")
				.replace(/^\/?images\//, "")
				.replace(/\/(?:412|768|1200)\.(?:avif|webp)$/, "")
				.replace(/\.[^.]+$/, ""),
			alt: bannerBlock?.alt || project.data.title,
		};
	});
}

const showProjectCarousel = projectSlides.length > 0;
const carouselId = "showcase-" + Math.random().toString(36).substring(2, 9);
---

<section class="editorial-section">
  <div class="editorial-shell">
    {eyebrow && <p class="editorial-eyebrow">{eyebrow}</p>}
    {title && <h2 class="editorial-heading editorial-heading--compact">{title}</h2>}

    {showProjectCarousel ? (
      <!-- Project carousel -->
      <div class="relative overflow-hidden w-full" id={carouselId}>
        <div
          class="carousel-track relative w-full h-[50vh] md:h-[70vh]"
          data-carousel={carouselId}
        >
          {projectSlides.map((slide, index) => (
            <a href={slide.href} class="carousel-slide w-full h-full bg-gray-100 block group hidden first:block">
              {slide.mediaId ? (
                <R2Picture
                  id={slide.mediaId}
                  alt={slide.alt}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                  eager={index === 0}
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-gray-400">
                  {slide.title}
                </div>
              )}
              <div class="absolute bottom-0 left-0 right-0 p-6 md:p-10 bg-gradient-to-t from-black/60 to-transparent z-10">
                <span class="text-white text-lg md:text-2xl font-light tracking-wide">{slide.title}</span>
              </div>
            </a>
          ))}
        </div>

        {projectSlides.length > 1 && (
          <>
            <button
              class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/80 hover:bg-white text-black rounded-full flex items-center justify-center shadow-lg transition-colors z-20"
              aria-label="Previous slide"
              data-carousel-prev={carouselId}
            >
              <span class="i-lucide-chevron-left w-6 h-6" />
            </button>
            <button
              class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/80 hover:bg-white text-black rounded-full flex items-center justify-center shadow-lg transition-colors z-20"
              aria-label="Next slide"
              data-carousel-next={carouselId}
            >
              <span class="i-lucide-chevron-right w-6 h-6" />
            </button>
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-3 z-20">
              {projectSlides.map((_, index) => (
                <button
                  class={`w-2.5 h-2.5 rounded-full transition-colors ${index === 0 ? 'bg-white' : 'bg-white/50 hover:bg-white/80'}`}
                  aria-label={`Go to slide ${index + 1}`}
                  data-carousel-dot={carouselId}
                  data-index={index}
                />
              ))}
            </div>
          </>
        )}
      </div>
    ) : items.length > 0 ? (
      <div class="grid gap-8 grid-cols-[repeat(auto-fit,minmax(min(100%,20rem),1fr))]">
        {items.map((item) => (
          <a href={item.link || '#'} class="flex flex-col gap-4 decoration-none text-inherit">
            <MediaPlaceholder
              mediaId={item.mediaId}
              alt={item.imageAlt}
              label={item.placeholderLabel}
              aspect="landscape"
            />
            <span class="text-[1.15rem] font-medium uppercase">{item.title}</span>
          </a>
        ))}
      </div>
    ) : (
      <MediaPlaceholder
        mediaId={mediaId}
        alt={imageAlt}
        kind={mediaType || 'image'}
        label={placeholderLabel}
        aspect="wide"
      />
    )}

    {ctaText && ctaLink && <a class="editorial-link mt-[clamp(2rem,5vw,4rem)]" href={ctaLink}>{ctaText}</a>}
  </div>
</section>

<script>
  const initCarousels = () => {
    document.querySelectorAll('[data-carousel]').forEach((track) => {
      if (track.hasAttribute('data-initialized')) return;
      track.setAttribute('data-initialized', 'true');

      const id = track.getAttribute('data-carousel');
      const container = track.parentElement;
      const slides = Array.from(track.querySelectorAll('.carousel-slide')) as HTMLElement[];
      const dots = container?.querySelectorAll(`[data-carousel-dot="${id}"]`);
      const prevBtn = container?.querySelector(`[data-carousel-prev="${id}"]`);
      const nextBtn = container?.querySelector(`[data-carousel-next="${id}"]`);

      if (slides.length <= 1) return;

      let current = 0;
      let isAnimating = false;

      // Initialize positions
      slides.forEach((slide, i) => {
        slide.style.position = 'absolute';
        slide.style.top = '0';
        slide.style.left = '0';
        slide.style.width = '100%';
        slide.style.height = '100%';
        slide.classList.remove('hidden'); // Remove hidden class used for fallback
        
        if (i === 0) {
          slide.style.transform = 'translateX(0)';
          slide.style.zIndex = '10';
        } else {
          slide.style.transform = 'translateX(100%)';
          slide.style.zIndex = '1';
        }
      });

      const updateDots = () => {
        dots?.forEach((dot, i) => {
          dot.classList.toggle('bg-white', i === current);
          dot.classList.toggle('bg-white/50', i !== current);
        });
      };

      const goTo = (nextIndex: number, direction: 'right' | 'left') => {
        if (isAnimating || nextIndex === current) return;
        isAnimating = true;

        const currentSlide = slides[current];
        const nextSlide = slides[nextIndex];

        // Prepare next slide position
        nextSlide.style.transition = 'none';
        nextSlide.style.transform = `translateX(${direction === 'right' ? '100%' : '-100%'})`;
        nextSlide.style.zIndex = '20';
        currentSlide.style.zIndex = '10';

        // Force reflow
        nextSlide.offsetHeight;

        // Animate
        nextSlide.style.transition = 'transform 0.5s ease-out';
        currentSlide.style.transition = 'transform 0.5s ease-out';
        
        nextSlide.style.transform = 'translateX(0)';
        currentSlide.style.transform = `translateX(${direction === 'right' ? '-100%' : '100%'})`;

        current = nextIndex;
        updateDots();

        setTimeout(() => {
          currentSlide.style.zIndex = '1';
          nextSlide.style.zIndex = '10';
          isAnimating = false;
        }, 500);
      };

      nextBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const next = current === slides.length - 1 ? 0 : current + 1;
        goTo(next, 'right');
      });

      prevBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const prev = current === 0 ? slides.length - 1 : current - 1;
        goTo(prev, 'left');
      });

      dots?.forEach((dot) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          const target = Number(dot.getAttribute('data-index'));
          if (target > current) goTo(target, 'right');
          else if (target < current) goTo(target, 'left');
        });
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousels);
  } else {
    initCarousels();
  }
</script>
