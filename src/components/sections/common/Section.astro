---
// src/components/sections/common/Section.astro
interface Props {
  title: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<section class="py-12 md:py-16" id={id}>
  <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
    <!-- Separator line -->
    <hr class="border-t border-neutral-200 mb-10 md:mb-14" />

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 lg:gap-24">
      <!-- Left column: Title -->
      <div>
        <h2 class="text-base md:text-lg font-sans font-medium tracking-tight uppercase">
          {title}
        </h2>
      </div>

      <!-- Right column: Content -->
      <div class="text-base md:text-lg leading-relaxed text-neutral-700 space-y-6">
        <slot />
      </div>
    </div>
  </div>
</section>
