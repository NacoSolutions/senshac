---
// src/components/sections/Gallery.astro
import OptimizedImage from '../../OptimizedImage.astro';

interface GalleryImage {
  src: string;
  alt?: string;
}

interface Props {
  cols?: '2' | '3' | '4';
  gap?: string;
  images?: GalleryImage[];
}

const { cols = '3', gap = '4', images = [] } = Astro.props;

const gridCols = {
  '2': 'grid-cols-1 md:grid-cols-2',
  '3': 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  '4': 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4',
};

// Calculate sizes based on column count
const sizesMap = {
  '2': '(min-width: 768px) 50vw, 100vw',
  '3': '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw',
  '4': '(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw',
};
---

<div class={`grid ${gridCols[cols]} gap-${gap} my-8`}>
  {images.map((image) => (
    <div class="aspect-4/3 overflow-hidden">
      <OptimizedImage
        src={image.src}
        alt={image.alt || ''}
        class="w-full h-full object-cover"
        loading="lazy"
        sizes={sizesMap[cols]}
      />
    </div>
  ))}
  <slot />
</div>
