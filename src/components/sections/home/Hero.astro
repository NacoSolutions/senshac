---
// src/components/sections/home/Hero.astro
import OptimizedImage from '../../OptimizedImage.astro';

interface Props {
  image: string;
  topRight?: {
    lines: string[];
  };
  tagline?: {
    lines: string[];
  };
  taglineSub?: string;
}

const { image, topRight, tagline, taglineSub } = Astro.props;
---

<section class="relative h-screen w-full overflow-hidden">
  <OptimizedImage
    src={image}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    sizes="100vw"
  />
  <div class="absolute inset-0 bg-black/20"></div>

  <div class="relative h-full max-w-7xl mx-auto px-4 flex flex-col justify-between py-8">
    {topRight && topRight.lines && (
      <div class="self-end text-white text-sm tracking-wider pt-16 md:pt-4">
        <div class="leading-tight text-right">
          {topRight.lines.map((line, i) => {
            const isEven = i % 2 === 1;
            return (
              <div class={isEven ? "translate-x-8" : ""}>{line}</div>
            );
          })}
        </div>
      </div>
    )}

    <div class="text-white text-left">
      {tagline && tagline.lines && (
        <h1 class="text-5xl md:text-7xl lg:text-[96px] font-sans font-medium leading-[1.2]">
          {tagline.lines.map((line) => (
            <span class="block">{line}</span>
          ))}
        </h1>
      )}
      {taglineSub && (
        <p class="text-lg md:text-xl mt-4 font-display">{taglineSub}</p>
      )}
    </div>
  </div>
</section>
