---
// src/components/sections/about/BehindName.astro
interface Props {
  title?: string;
  p1?: string;
  p2?: string;
  footnote?: string;
}

const { title, p1, p2, footnote } = Astro.props;
---

<section class="pt-8 pb-16 md:pt-12 md:pb-24 bg-section-light">
  <div class="container-content">
    <!-- Separator line -->
    <hr class="border-t border-neutral-300 mb-12 md:mb-16" />

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 lg:gap-24">
      <!-- Left column: Title -->
      <div>
        {title && (
          <h2 class="text-sm md:text-base font-medium tracking-widest uppercase">
            {title}
          </h2>
        )}
      </div>

      <!-- Right column: Content -->
      <div class="space-y-6">
        <div class="space-y-6 text-base md:text-lg leading-relaxed text-neutral-700">
          {p1 && <p>{p1}</p>}
          {p2 && <p>{p2}</p>}
        </div>
        {footnote && (
          <p class="mt-8 text-xs md:text-sm text-neutral-500 italic">
            {footnote}
          </p>
        )}
      </div>
    </div>
  </div>
</section>
