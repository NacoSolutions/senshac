---
// src/components/sections/about/Hero.astro
interface Props {
  title: string;
}

const { title } = Astro.props;

// Parse title to apply italic styling to "sense hac*" portion
// Expected format: "Ester sense hac*, please." or similar
const parts = title.match(/^(.+?)\s+(sense\s+hac\*?),?\s*(.*)$/i);
---

<section class="pt-24 pb-12 md:pt-32 md:pb-16 bg-section-light">
  <div class="container-content">
    <h1 class="sinteca-big-title text-center">
      {parts ? (
        <>
          <span>{parts[1]}</span>{' '}
          <em class="italic">{parts[2]}</em>
          {parts[3] && <span>, {parts[3]}</span>}
        </>
      ) : (
        title
      )}
    </h1>
  </div>
</section>
