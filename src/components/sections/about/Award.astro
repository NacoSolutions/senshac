---
// src/components/sections/about/Award.astro
interface Props {
  year: string;
  project: string;
  award: string;
  link?: string;
}

const { year, project, award, link } = Astro.props;
---

<div class="border-b border-neutral-200 py-6 md:py-8">
  <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
    <span class="text-sm md:text-base text-neutral-500 w-12 md:w-16 shrink-0">
      {year}
    </span>
    <span class="text-sm md:text-base font-medium text-neutral-900 w-32 md:w-48 shrink-0">
      {project}
    </span>
    <span class="text-sm md:text-base text-neutral-700 flex-1 min-w-0">
      {award}
    </span>
    {link && (
      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 text-neutral-900 hover:text-neutral-600 transition-colors"
        aria-label={`Learn more about ${award}`}
      >
        <span class="i-lucide-arrow-up-right w-5 h-5 md:w-6 md:h-6" aria-hidden="true" />
      </a>
    )}
  </div>
</div>
