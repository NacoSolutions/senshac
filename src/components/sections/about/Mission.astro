---
// src/components/sections/about/Mission.astro
interface Props {
  title?: string;
  p1?: string;
  p2?: string;
  quote?: string;
}

const { title, p1, p2, quote } = Astro.props;
---

<section class="py-16 md:py-24">
  <div class="container-content">
    <!-- Two-column layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 lg:gap-24">
      <!-- Left column: Title -->
      <div>
        {title && (
          <h2 class="sinteca-small-title">
            {title.toUpperCase()}
          </h2>
        )}
      </div>

      <!-- Right column: Content -->
      <div class="space-y-6">
        {p1 && (
          <p class="text-base md:text-lg font-semibold leading-relaxed text-neutral-900">
            {p1}
          </p>
        )}
        {p2 && (
          <p class="text-base md:text-lg leading-relaxed text-neutral-700">
            {p2}
          </p>
        )}
      </div>
    </div>

    <!-- Full-width quote -->
    {quote && (
      <blockquote class="mt-16 md:mt-24 text-2xl md:text-4xl lg:text-5xl font-medium leading-tight tracking-tight text-neutral-900 uppercase">
        {quote}
      </blockquote>
    )}
  </div>
</section>
