---
// src/components/SEO.astro
import { getSiteConfig } from "../utils/site-config";

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: "website" | "article";
	publishDate?: Date;
	schema?:
		| "LocalBusiness"
		| "Article"
		| "BreadcrumbList"
		| Array<"LocalBusiness" | "Article" | "BreadcrumbList">;
	breadcrumbs?: { name: string; url: string }[];
	lang?: string;
}

const {
	title,
	description,
	image,
	type = "website",
	publishDate,
	schema,
	breadcrumbs,
	lang = "es",
} = Astro.props;

const site = await getSiteConfig();
const mediaBaseUrl = (
	import.meta.env.PUBLIC_MEDIA_BASE_URL || "https://media.senshac.com"
).replace(/\/$/, "");
const mediaUrl = (id: string) =>
	`${mediaBaseUrl}/images/${id.replace(/^\/?images\//, "").replace(/\.[^.]+$/, "")}/1200.webp`;

// Use locales from site config
const locales = site.locales;
const localeMap: Record<string, string> = {
	es: "es_ES",
	ca: "ca_ES",
	en: "en_US",
};

// Build alternate URLs for hreflang
const pathname = Astro.url.pathname;
const localePattern = new RegExp(`^\\/(${locales.join("|")})`);
const pathWithoutLang = pathname.replace(localePattern, "") || "/";
const alternateUrls = locales.map((locale) => ({
	lang: locale,
	url: Astro.site
		? new URL(`/${locale}${pathWithoutLang}`, Astro.site).toString()
		: `/${locale}${pathWithoutLang}`,
}));

const canonicalURL = Astro.site
	? new URL(Astro.url.pathname, Astro.site)
	: Astro.url;

const requestedImage = image || site.branding.ogImage;
const ogImage = /^https?:\/\//.test(requestedImage)
	? requestedImage
	: mediaUrl(requestedImage);

// Build sameAs array from social links
const sameAs = site.socialLinks.map((link: { url: string }) => link.url);

// LocalBusiness schema for homepage
const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"@id": Astro.site?.toString() || "",
	name: site.company.name,
	description: site.company.description,
	url: Astro.site?.toString() || "",
	telephone: site.contact.phone,
	email: site.contact.email,
	address: {
		"@type": "PostalAddress",
		addressLocality: site.contact.location.city,
		addressCountry: site.contact.location.country,
	},
	founder: {
		"@type": "Person",
		name: site.founder.name,
	},
	sameAs,
	priceRange: site.seo?.priceRange || "$$",
	image: ogImage,
};

// Article schema for projects
const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: title,
	description: description,
	image: ogImage,
	datePublished: publishDate?.toISOString(),
	author: {
		"@type": "Person",
		name: site.founder.name,
	},
	publisher: {
		"@type": "Organization",
		name: site.company.name,
		logo: {
			"@type": "ImageObject",
			url: mediaUrl(site.branding.logo),
		},
	},
};

// BreadcrumbList schema
const breadcrumbSchema = breadcrumbs
	? {
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			itemListElement: breadcrumbs.map((item, index) => ({
				"@type": "ListItem",
				position: index + 1,
				name: item.name,
				item: Astro.site ? new URL(item.url, Astro.site).toString() : item.url,
			})),
		}
	: null;

const getSchema = (type: string) => {
	switch (type) {
		case "LocalBusiness":
			return localBusinessSchema;
		case "Article":
			return articleSchema;
		case "BreadcrumbList":
			return breadcrumbSchema;
		default:
			return null;
	}
};

const schemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const schemaData = schemas.map(getSchema).filter(Boolean);
const fullTitle = title.includes(site.company.name)
	? title
	: `${title} | ${site.company.name}`;
---

<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />
<link rel="author" href="/humans.txt" type="text/plain" />

<!-- Hreflang alternates -->
{alternateUrls.map(alt => (
  <link rel="alternate" hreflang={alt.lang} href={alt.url} />
))}
<link rel="alternate" hreflang="x-default" href={alternateUrls.find(a => a.lang === 'es')?.url} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<meta name="author" content={`${site.company.name} - ${site.founder.name}`} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={site.company.name} />
<meta property="og:locale" content={localeMap[lang] || 'es_ES'} />
{locales.filter(l => l !== lang).map(l => (
  <meta property="og:locale:alternate" content={localeMap[l]} />
))}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- JSON-LD Structured Data -->
{schemaData.map(data => (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(data)} />
))}
