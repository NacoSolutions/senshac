---
// src/components/islands/LegalPage.astro
import TinaMarkdown from '@tinacms/astro/TinaMarkdown.astro';
import type { LegalQuery } from '../../../tina/__generated__/types';

interface Props {
  data: LegalQuery['legal'];
}

const { data } = Astro.props;
---
<section class="py-16 md:py-24">
  <div class="max-w-4xl mx-auto px-4">
    <article class="prose prose-lg max-w-none prose-headings:font-display prose-h1:text-4xl prose-h1:mb-8 prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h3:text-lg prose-h3:mt-8 prose-p:text-gray-600 prose-ul:text-gray-600 prose-li:marker:text-gray-400">
      <TinaMarkdown content={data.body} />
    </article>
  </div>
</section>
