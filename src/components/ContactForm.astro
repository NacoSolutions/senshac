---
import { tinaField } from "@tinacms/astro";
import type { TranslationsQuery } from "../../tina/__generated__/types";
// src/components/ContactForm.astro
import { getTinaRuntimeEnv, getTranslations } from "../lib/tina-data";

interface Props {
	lang: string;
	translations?: TranslationsQuery["translations"];
}

const { lang, translations: propTranslations } = Astro.props;

let t = propTranslations;
if (!t) {
	const tinaEnv = getTinaRuntimeEnv(Astro.locals);
	const transRes = await getTranslations(`${lang}.json`, tinaEnv);
	t = transRes.data.translations;
}
const f = t.contactForm as any;

// Turnstile site key - use test key for development
const TURNSTILE_SITE_KEY =
	import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "1x00000000000000000000AA"; // gitleaks:allow

const success = Astro.url.searchParams.get("contact_success");
const error = Astro.url.searchParams.get("contact_error");
---

{success === "1" ? (
  <div class="p-6 bg-green-50 border border-green-200 text-green-800 rounded text-center" id="contact-form">
    <svg class="w-12 h-12 mx-auto mb-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
    </svg>
    <p class="text-lg font-medium">{f.success}</p>
  </div>
) : (
<div id="contact-form-container">
  <div id="form-feedback">
    {error && (
      <div class="p-4 bg-red-50 border border-red-200 text-red-800 rounded">
        {f[error] || f.error}
      </div>
    )}
  </div>
  <form
    id="contact-form"
    class="space-y-6 mt-6"
    action={`/${lang}/api/contact`}
    method="POST"
    hx-post={`/${lang}/api/contact`}
    hx-target="#form-feedback"
    hx-swap="innerHTML"
    hx-indicator="#form-indicator"
  >
  <!-- Name + Company row -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <input
        type="text"
        name="name"
        placeholder={`${f.name}*`}
        required
        class="w-full px-4 py-3 border-b border-gray-300 focus:outline-none focus:border-black transition-colors bg-transparent"
        data-tina-field={tinaField(f, 'name')}
      />
    </div>
    <div>
      <input
        type="text"
        name="company"
        placeholder={f.company}
        class="w-full px-4 py-3 border-b border-gray-300 focus:outline-none focus:border-black transition-colors bg-transparent"
        data-tina-field={tinaField(f, 'company')}
      />
    </div>
  </div>

  <!-- Email + Phone row -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <input
        type="email"
        name="email"
        placeholder={`${f.email}*`}
        required
        class="w-full px-4 py-3 border-b border-gray-300 focus:outline-none focus:border-black transition-colors bg-transparent"
        data-tina-field={tinaField(f, 'email')}
      />
    </div>
    <div>
      <input
        type="tel"
        name="phone"
        placeholder={f.phone}
        class="w-full px-4 py-3 border-b border-gray-300 focus:outline-none focus:border-black transition-colors bg-transparent"
        data-tina-field={tinaField(f, 'phone')}
      />
    </div>
  </div>

  <!-- Project Type -->
  <div>
      <select
        name="projectType"
        required
        class="w-full px-4 py-3 border-b border-gray-300 focus:outline-none focus:border-black transition-colors bg-transparent text-gray-500"
        data-tina-field={tinaField(f, 'projectType')}
      >
        <option value="">{f.projectType}*</option>
        {f.projectTypes?.map((pt: any, index: number) => (
          <option value={pt.value} data-tina-field={tinaField(f.projectTypes, index)}>{pt.label}</option>
        ))}
      </select>
  </div>

  <!-- Service Type -->
  <div>
      <select
        name="serviceType"
        required
        class="w-full px-4 py-3 border-b border-gray-300 focus:outline-none focus:border-black transition-colors bg-transparent text-gray-500"
        data-tina-field={tinaField(f, 'serviceType')}
      >
        <option value="">{f.serviceType}*</option>
        {f.serviceTypes?.map((st: any, index: number) => (
          <option value={st.value} data-tina-field={tinaField(f.serviceTypes, index)}>{st.label}</option>
        ))}
      </select>
  </div>

  <!-- Message -->
  <div>
    <textarea
      name="message"
      rows="4"
      placeholder={f.message}
      class="w-full px-4 py-3 border-b border-gray-300 focus:outline-none focus:border-black transition-colors bg-transparent resize-none"
      data-tina-field={tinaField(f, 'message')}
    ></textarea>
  </div>

  <!-- Privacy -->
  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      name="privacy"
      id="privacy"
      required
      class="mt-1 w-4 h-4 border-gray-300 rounded focus:ring-black"
    />
    <label for="privacy" class="text-sm text-gray-600" data-tina-field={tinaField(f, 'privacy')}>
      {f.privacy}
    </label>
  </div>

  <!-- Turnstile (invisible) -->
  <div
    class="cf-turnstile"
    data-sitekey={TURNSTILE_SITE_KEY}
    data-size="invisible"
    data-callback="onTurnstileSuccess"
    data-error-callback="onTurnstileError"
  ></div>
  <input type="hidden" name="cf-turnstile-response" id="cf-turnstile-response" />

  <!-- Submit -->
  <div>
    <button
      type="submit"
      class="px-8 py-4 bg-black text-white tracking-wider text-sm hover:bg-gray-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      data-tina-field={tinaField(f, 'submit')}
    >
      <span class="htmx-indicator-hide">{f.submit}</span>
      <span id="form-indicator" class="htmx-indicator" data-tina-field={tinaField(f, 'sending')}>{f.sending}</span>
    </button>
  </div>
</form>
</div>
)}

<style>
  .htmx-indicator {
    display: none;
  }
  .htmx-request .htmx-indicator {
    display: inline;
  }
  .htmx-request .htmx-indicator-hide {
    display: none;
  }
</style>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
<script is:inline>
  // HTMX validation interceptor for Turnstile
  document.addEventListener('htmx:confirm', function(e) {
    if (e.target.id === 'contact-form') {
      const responseInput = document.querySelector('#contact-form [name="cf-turnstile-response"]');
      if (responseInput && !responseInput.value) {
        // Prevent HTMX from submitting
        e.preventDefault();
        
        // Save the event to trigger later
        window.pendingHtmxEvent = e;
        
        // Render and execute turnstile if not already rendered
        const widgetContainer = document.querySelector('#contact-form-container .cf-turnstile');
        let widgetId = widgetContainer.getAttribute('data-turnstile-id');
        if (!widgetId) {
          widgetId = turnstile.render(widgetContainer, {
            sitekey: widgetContainer.getAttribute('data-sitekey'),
            size: 'invisible',
            callback: 'onTurnstileSuccess',
            'error-callback': 'onTurnstileError'
          });
          widgetContainer.setAttribute('data-turnstile-id', widgetId);
        }
        turnstile.execute(widgetContainer.getAttribute('data-turnstile-id'));
      }
    }
  });

  // Turnstile callbacks scoped to the form
  window.onTurnstileSuccess = function(token) {
    const responseInput = document.querySelector('#contact-form [name="cf-turnstile-response"]');
    if (responseInput) responseInput.value = token;
    
    // Resume HTMX submission
    if (window.pendingHtmxEvent) {
      window.pendingHtmxEvent.detail.issueRequest();
      window.pendingHtmxEvent = null;
    }
  };
  window.onTurnstileError = function() {
    console.error('Turnstile error');
    // We could show an error here manually, or trigger a failure
  };
</script>

<script>
  // Load HTMX only where the form is used
  import htmx from 'htmx.org';
  window.htmx = htmx;
  // Initialize HTMX explicitly because this script is bundled and deferred
  htmx.process(document.body);
</script>
