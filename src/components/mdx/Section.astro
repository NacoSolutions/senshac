---
// src/components/mdx/Section.astro
interface Props {
  title: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<section class="py-16 md:py-24" id={id}>
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-display mb-8">{title}</h2>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </div>
</section>
