---
// src/components/mdx/Figure.astro
interface Props {
  src: string;
  alt?: string;
  caption?: string;
  width?: string;
}

const { src, alt = '', caption, width } = Astro.props;
const maxWidth = width ? `max-width: ${width}` : '';
---

<figure class="my-8" style={maxWidth}>
  <img src={src} alt={alt} class="w-full" loading="lazy" />
  {caption && (
    <figcaption class="mt-2 text-sm text-gray-600 italic">{caption}</figcaption>
  )}
</figure>
