---
// src/components/mdx/FAQSection.astro
interface Props {
  title?: string;
  image?: string;
}

const { title = "FAQ's", image } = Astro.props;
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-display mb-12">{title}</h2>
    <div class="border-b border-gray-200">
      <slot />
    </div>
    {image && (
      <div class="mt-16">
        <img src={image} alt="" class="w-full" loading="lazy" />
      </div>
    )}
  </div>
</section>
