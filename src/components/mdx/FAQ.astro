---
// src/components/mdx/FAQ.astro
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<details class="border-t border-gray-200 py-6 group">
  <summary class="flex justify-between items-center cursor-pointer list-none">
    <span class="font-medium pr-4">{question}</span>
    <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center">
      <svg
        class="w-4 h-4 transition-transform group-open:rotate-45"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6" />
      </svg>
    </span>
  </summary>
  <p class="mt-4 text-gray-600">{answer}</p>
</details>
