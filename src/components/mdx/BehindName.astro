---
// src/components/mdx/BehindName.astro
interface Props {
  title?: string;
  p1?: string;
  p2?: string;
  footnote?: string;
}

const { title, p1, p2, footnote } = Astro.props;
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-4xl mx-auto px-4">
    {title && <h2 class="text-2xl md:text-3xl font-display mb-8">{title}</h2>}
    <div class="space-y-6 text-lg text-gray-600">
      {p1 && <p>{p1}</p>}
      {p2 && <p>{p2}</p>}
    </div>
    {footnote && (
      <p class="mt-8 text-sm text-gray-500 italic">{footnote}</p>
    )}
  </div>
</section>
