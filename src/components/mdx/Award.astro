---
// src/components/mdx/Award.astro
interface Props {
  year: string;
  project: string;
  award: string;
  link?: string;
}

const { year, project, award, link } = Astro.props;
---

<div class="border-t border-gray-200 py-6 grid grid-cols-4 gap-4">
  <span class="text-gray-500">{year}</span>
  <span class="col-span-2">{project}</span>
  {link ? (
    <a href={link} target="_blank" rel="noopener" class="text-gray-600 hover:text-black transition-colors">
      {award}
    </a>
  ) : (
    <span class="text-gray-600">{award}</span>
  )}
</div>
