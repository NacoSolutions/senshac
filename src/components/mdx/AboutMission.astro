---
// src/components/mdx/AboutMission.astro
interface Props {
  title?: string;
  p1?: string;
  p2?: string;
  quote?: string;
}

const { title, p1, p2, quote } = Astro.props;
---

<section class="py-16 md:py-24 bg-black text-white">
  <div class="max-w-4xl mx-auto px-4">
    {title && <h2 class="text-2xl md:text-3xl font-display mb-8">{title}</h2>}
    <div class="space-y-6 text-lg text-gray-300">
      {p1 && <p>{p1}</p>}
      {p2 && <p>{p2}</p>}
    </div>
    {quote && (
      <blockquote class="mt-12 text-2xl md:text-3xl font-display leading-relaxed">
        "{quote}"
      </blockquote>
    )}
  </div>
</section>
