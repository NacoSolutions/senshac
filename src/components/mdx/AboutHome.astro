---
// src/components/mdx/AboutHome.astro
interface Props {
  image?: string;
  title?: string;
  description?: string;
  cta?: string;
  ctaLink?: string;
}

const { image, title, description, cta, ctaLink } = Astro.props;
---

<section class="py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      {image && (
        <div class="aspect-4/3 overflow-hidden">
          <img src={image} alt="" class="w-full h-full object-cover" loading="lazy" />
        </div>
      )}

      <div>
        {title && (
          <h2 class="text-3xl md:text-4xl font-display leading-tight mb-6">
            {title}
          </h2>
        )}
        {description && (
          <p class="text-lg text-gray-600 mb-8">{description}</p>
        )}
        {cta && ctaLink && (
          <a
            href={ctaLink}
            class="inline-block border-b-2 border-black pb-1 text-sm font-medium hover:opacity-70 transition-opacity"
          >
            {cta}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
