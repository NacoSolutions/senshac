---
// src/components/mdx/DetailsSection.astro
interface Props {
  title: string;
  subtitle?: string;
  services: string;
  servicesLabel?: string;
  category: string;
  categoryLabel?: string;
  area: string;
  areaLabel?: string;
  location: string;
  locationLabel?: string;
  image?: string;
}

const {
  title,
  subtitle,
  services,
  servicesLabel = 'SERVICES',
  category,
  categoryLabel = 'CATEGORY',
  area,
  areaLabel = 'AREA',
  location,
  locationLabel = 'LOCATION',
  image,
} = Astro.props;
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <h1 class="text-4xl md:text-5xl font-display mb-4">{title}</h1>
        {subtitle && <p class="text-xl text-gray-600">{subtitle}</p>}

        <div class="mt-12 grid grid-cols-2 gap-8">
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">{servicesLabel}</p>
            <p class="text-sm">{services}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">{categoryLabel}</p>
            <p class="text-sm">{category}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">{areaLabel}</p>
            <p class="text-sm">{area}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">{locationLabel}</p>
            <p class="text-sm">{location}</p>
          </div>
        </div>
      </div>

      {image && (
        <div class="aspect-4/3 overflow-hidden">
          <img src={image} alt={title} class="w-full h-full object-cover" loading="eager" />
        </div>
      )}
    </div>
  </div>
</section>
