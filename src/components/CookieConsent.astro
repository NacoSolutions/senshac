---
// src/components/CookieConsent.astro
interface Props {
  lang: string;
}

const { lang } = Astro.props;

const translations = {
  es: {
    message: 'Este sitio utiliza cookies para ofrecerte una mejor experiencia de navegación. Al navegar por este sitio web, aceptas el uso de cookies.',
    moreInfo: 'Más información',
    accept: 'Aceptar',
  },
  ca: {
    message: 'Aquest lloc utilitza cookies per oferir-te una millor experiència de navegació. En navegar per aquest lloc web, acceptes l\'ús de cookies.',
    moreInfo: 'Més informació',
    accept: 'Acceptar',
  },
  en: {
    message: 'This site uses cookies to offer you a better browsing experience. By browsing this website, you agree to our use of cookies.',
    moreInfo: 'More info',
    accept: 'Accept',
  },
};

const t = translations[lang as keyof typeof translations] || translations.es;
---

<div
  id="cookie-consent"
  class="fixed bottom-0 left-0 right-0 bg-black/90 text-white p-4 z-50 transform translate-y-full transition-transform duration-300"
  x-data="{ show: false }"
  x-init="show = !localStorage.getItem('cookieConsent')"
  x-show="show"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="translate-y-full"
  x-transition:enter-end="translate-y-0"
  x-transition:leave="transition ease-in duration-300"
  x-transition:leave-start="translate-y-0"
  x-transition:leave-end="translate-y-full"
>
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-gray-300 text-center sm:text-left">
      {t.message}
    </p>
    <div class="flex items-center gap-4">
      <a
        href={`/${lang}/privacy-policy`}
        class="text-sm text-gray-400 hover:text-white transition-colors underline"
      >
        {t.moreInfo}
      </a>
      <button
        type="button"
        class="bg-white text-black px-4 py-2 text-sm hover:bg-gray-200 transition-colors"
        @click="localStorage.setItem('cookieConsent', 'true'); show = false"
      >
        {t.accept}
      </button>
    </div>
  </div>
</div>
