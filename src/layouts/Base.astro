---
// src/layouts/Base.astro
// Note: virtual:uno.css is auto-injected by @unocss/astro integration
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import HeaderIsland from '../components/islands/HeaderIsland.astro';
import FooterIsland from '../components/islands/FooterIsland.astro';
import { getTinaRuntimeEnv, getTranslations, getSiteConfigTina } from '../lib/tina-data';
import { createIslands } from '../lib/tina-islands';
interface Props {
  title: string;
  description: string;
  image?: string;
  lang?: string;
  schema?: 'LocalBusiness' | 'Article' | 'BreadcrumbList';
  publishDate?: Date;
  breadcrumbs?: { name: string; url: string }[];
  headerStyle?: 'default' | 'transparent';
  preloadImage?: string;
}

const { title, description, image, lang = 'es', schema, publishDate, breadcrumbs, headerStyle = 'default', preloadImage } = Astro.props;

const tinaEnv = getTinaRuntimeEnv(Astro.locals);
const islands = createIslands(tinaEnv);
const translationsPath = `${lang}.json`;
const tinaTranslationsRes = await getTranslations(translationsPath, tinaEnv);
const tinaTranslationsData = tinaTranslationsRes.data.translations;

const tinaSiteRes = await getSiteConfigTina('site.json', tinaEnv);
const tinaSiteData = tinaSiteRes.data.siteConfig;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <SEO
      title={title}
      description={description}
      image={image}
      schema={schema}
      publishDate={publishDate}
      breadcrumbs={breadcrumbs}
      lang={lang}
    />

    <!-- Preload custom fonts -->
    <link rel="preload" href="/fonts/jozsika-light.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sinteca-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sinteca-medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sinteca-semibold.woff2" as="font" type="font/woff2" crossorigin />

    {preloadImage && <link rel="preload" href={preloadImage} as="image" type="image/webp" fetchpriority="high" />}

    <slot name="head" />
  </head>
  <body class:list={["font-sans antialiased", headerStyle === 'default' && "pt-20"]}>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-black focus:text-white focus:px-4 focus:py-2">
      Skip to content
    </a>
    <TinaIsland name="header" wrapper={islands.header.wrapper} params={{ relativePath: translationsPath, lang, headerStyle }}>
      <HeaderIsland data={tinaTranslationsData} siteData={tinaSiteData} lang={lang} headerStyle={headerStyle} />
    </TinaIsland>

    <slot />

    <TinaIsland name="footer" wrapper={islands.footer.wrapper} params={{ relativePath: translationsPath, lang }}>
      <FooterIsland data={tinaTranslationsData} siteData={tinaSiteData} lang={lang} />
    </TinaIsland>

    <!-- Custom cursor circle -->
    <div id="cursor-circle"></div>

    <!-- Alpine.js -->
    <script>
      import Alpine from 'alpinejs';
      // @ts-expect-error - @alpinejs/collapse has no type declarations
      import collapse from '@alpinejs/collapse';
      Alpine.plugin(collapse);
      window.Alpine = Alpine;
      Alpine.start();
    </script>

    <!-- HTMX -->
    <script>
      import htmx from 'htmx.org';
      window.htmx = htmx;
    </script>

    <!-- Hyperscript -->
    <script>
      import 'hyperscript.org';
    </script>

    <!-- Custom cursor effect - matches WordPress theme -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const circle = document.getElementById('cursor-circle') as HTMLElement | null;
        if (!circle) return;
        const el = circle; // TypeScript narrowing helper

        let mouseX = 0, mouseY = 0;
        let circleX = 0, circleY = 0;
        let scale = 1;
        let hideTimeout: ReturnType<typeof setTimeout> | null = null;
        const IDLE_HIDE_DELAY = 2000; // Hide after 2 seconds of no movement

        const showCursor = () => {
          el.style.opacity = '1';
          // Reset hide timeout on any movement
          if (hideTimeout) clearTimeout(hideTimeout);
          hideTimeout = setTimeout(() => {
            el.style.opacity = '0';
          }, IDLE_HIDE_DELAY);
        };

        // Add hoverable effect to elements
        document.querySelectorAll('a, button, .hoverable').forEach(el => {
          el.addEventListener('mouseenter', () => {
            scale = 2;
            showCursor();
          });
          el.addEventListener('mouseleave', () => {
            scale = 1;
          });
        });

        // Show cursor when entering document
        document.addEventListener('mouseenter', () => {
          showCursor();
        });

        // Hide cursor when leaving document
        document.addEventListener('mouseleave', () => {
          if (hideTimeout) clearTimeout(hideTimeout);
          el.style.opacity = '0';
        });

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          showCursor();
        });

        // Smooth animation loop
        function animate() {
          circleX += (mouseX - circleX) * 0.15;
          circleY += (mouseY - circleY) * 0.15;
          el.style.left = circleX + 'px';
          el.style.top = circleY + 'px';
          el.style.transform = `translate(-50%, -50%) scale(${scale})`;
          requestAnimationFrame(animate);
        }
        animate();
      });
    </script>
    <script is:inline>
      // Allow click-through navigation in TinaCMS iframe by holding Alt or Meta/Ctrl
      document.addEventListener('click', function(e) {
        if (e.altKey || e.metaKey || e.ctrlKey || e.shiftKey) {
          const link = e.target.closest('a');
          if (link && link.href) {
            e.stopPropagation(); // Prevent TinaCMS from intercepting
            e.preventDefault();  // Stop default so we can control navigation
            if (link.target === '_blank') {
              window.open(link.href, '_blank');
            } else {
              window.location.href = link.href;
            }
          }
        }
      }, true); // Use capture phase to run before Tina's listeners
    </script>
  </body>
</html>
