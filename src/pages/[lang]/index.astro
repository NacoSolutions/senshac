---
// src/pages/[lang]/index.astro
import Base from '../../layouts/Base.astro';
import { getEntry } from 'astro:content';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import Hero from '../../components/sections/home/Hero.astro';
import About from '../../components/sections/home/About.astro';
import HomePage from '../../components/islands/HomePage.astro';
import { getHome, getTinaRuntimeEnv, pageRelativePath } from '../../lib/tina-data';
import { createIslands } from '../../lib/tina-islands';

const { lang } = Astro.params;

const page = await getEntry('pages', `${lang}/home`);

if (!page) {
  return Astro.redirect('/404');
}

const { title, description, headerStyle, hero, about } = page.data as {
  title: string;
  description: string;
  headerStyle: 'default' | 'transparent';
  hero: {
    image: string;
    topRight?: { lines: string[] };
    tagline?: { lines: string[] };
    taglineSub?: string;
  };
  about: { image?: string; title?: string; description?: string; ctaText?: string; ctaLink?: string };
};

const tinaEnv = getTinaRuntimeEnv(Astro.locals);
const islands = createIslands(tinaEnv);
const relativePath = pageRelativePath(lang, 'home.json');
const tinaHome = await getHome(relativePath, tinaEnv);
const tinaHomeData = tinaHome.data.home;
---

<Base title={title} description={description} lang={lang} schema="LocalBusiness" headerStyle={headerStyle}>
  {tinaHomeData ? (
    <TinaIsland name="home" wrapper={islands.home.wrapper} params={{ relativePath }} primary>
      <HomePage data={tinaHomeData} />
    </TinaIsland>
  ) : (
    <main id="main">
      <Hero
        image={hero.image}
        topRight={hero.topRight}
        tagline={hero.tagline}
        taglineSub={hero.taglineSub}
      />
      <About
        image={about.image}
        title={about.title}
        description={about.description}
        cta={about.ctaText}
        ctaLink={about.ctaLink}
      />
    </main>
  )}
</Base>
