---
// src/pages/[lang]/works/index.astro
import Base from '../../../layouts/Base.astro';
import OptimizedImage from '../../../components/OptimizedImage.astro';
import { getCollection, getEntry } from 'astro:content';

const { lang } = Astro.params;

const projects = await getCollection('projects', ({ id, data }) => {
  return id.startsWith(`${lang}/`) && !data.draft;
});

// Sort projects by date (newest first)
projects.sort((a, b) => {
  const dateA = a.data.completedDate || a.data.publishDate;
  const dateB = b.data.completedDate || b.data.publishDate;
  return new Date(dateB).getTime() - new Date(dateA).getTime();
});

const translations = await getEntry('translations', lang as string);
const t = translations?.data.projects;

if (!t) {
  return Astro.redirect('/404');
}
---

<Base title={t.title} description={t.description} lang={lang as string}>
  <main class="min-h-screen">
    <!-- Header Section -->
    <section class="bg-white">
      <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
        <div class="h-[90px]"></div>

        <!-- Title with border bottom -->
        <div class="border-b border-neutral-900 pb-8">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-sans font-medium tracking-tight">{t?.heading}</h1>
        </div>
      </div>
    </section>

    <!-- Projects List -->
    <section class="bg-white py-12 md:py-16">
      <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
        <div class="space-y-16 md:space-y-24">
          {projects.map((project) => {
            const bannerBlock = project.data.blocks?.find((b: any) => b._template === 'projectBanner' || b._template === 'bannerImage');
            const bannerImage = bannerBlock?.image || '';
            return (
            <a href={`/${lang}/works/${project.data.slug}`} class="block group">
              <article class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 lg:gap-16 items-start">
                <!-- Project Image -->
                <div class="aspect-[4/3] overflow-hidden">
                  <OptimizedImage
                    src={bannerImage}
                    alt={project.data.title}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                    sizes="(min-width: 768px) 50vw, 100vw"
                  />
                </div>

                <!-- Project Content -->
                <div class="flex flex-col justify-start pt-0 md:pt-4">
                  <h2 class="text-xl md:text-2xl lg:text-3xl font-sans font-medium tracking-tight uppercase border-b border-neutral-900 pb-4 inline-block group-hover:text-neutral-600 transition-colors">
                    {project.data.title}
                  </h2>
                  {project.data.showTags && project.data.tags && project.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {project.data.tags.map((tag: string) => (
                        <span class="text-xs uppercase tracking-wider text-neutral-500">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            </a>
            );
          })}
        </div>
      </div>
    </section>
  </main>
</Base>
