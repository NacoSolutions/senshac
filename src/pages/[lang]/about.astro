---
// src/pages/[lang]/about.astro
import Base from '../../layouts/Base.astro';
import { getEntry } from 'astro:content';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import Hero from '../../components/sections/about/Hero.astro';
import BehindName from '../../components/sections/about/BehindName.astro';
import Banner from '../../components/sections/common/Banner.astro';
import Bio from '../../components/sections/about/Bio.astro';
import Awards from '../../components/sections/about/Awards.astro';
import Award from '../../components/sections/about/Award.astro';
import Mission from '../../components/sections/about/Mission.astro';
import AboutPage from '../../components/islands/AboutPage.astro';
import { getAbout, getTinaRuntimeEnv, pageRelativePath } from '../../lib/tina-data';
import { createIslands } from '../../lib/tina-islands';

const { lang } = Astro.params;

const page = await getEntry('pages', `${lang}/about`);

if (!page) {
  return Astro.redirect('/404');
}

const { title, description, hero, behindName, bannerImage, bio, awards, mission, missionImage } = page.data as {
  title: string;
  description: string;
  hero: { title: string };
  behindName: { title?: string; p1: string; p2: string; footnote?: string };
  bannerImage?: string;
  bio: { title?: string; image?: string; paragraphs: string[] };
  awards: { title?: string; items: { year: string; project: string; award: string; link?: string }[] };
  mission: { title?: string; p1: string; p2: string; quote?: string };
  missionImage?: string;
};

const tinaEnv = getTinaRuntimeEnv(Astro.locals);
const islands = createIslands(tinaEnv);
const relativePath = pageRelativePath(lang, 'about.json');
const tinaAbout = await getAbout(relativePath, tinaEnv);
const tinaAboutData = tinaAbout.data.about;
---

<Base title={title} description={description} lang={lang}>
  {tinaAboutData ? (
    <TinaIsland name="about" wrapper={islands.about.wrapper} params={{ relativePath }} primary>
      <AboutPage data={tinaAboutData} />
    </TinaIsland>
  ) : (
    <main class="min-h-screen">
      <Hero title={hero.title} />

      <BehindName
        title={behindName.title}
        p1={behindName.p1}
        p2={behindName.p2}
        footnote={behindName.footnote}
      />

      {bannerImage && <Banner src={bannerImage} alt="Behind the name" />}

      <Bio
        title={bio.title}
        image={bio.image}
        paragraphs={bio.paragraphs}
      />

      <Awards title={awards.title}>
        {awards.items.map((item) => (
          <Award
            year={item.year}
            project={item.project}
            award={item.award}
            link={item.link}
          />
        ))}
      </Awards>

      <Mission
        title={mission.title}
        p1={mission.p1}
        p2={mission.p2}
        quote={mission.quote}
      />

      {missionImage && <Banner src={missionImage} alt="Our mission" />}
    </main>
  )}
</Base>
