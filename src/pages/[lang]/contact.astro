---
// src/pages/[lang]/contact.astro
import Base from '../../layouts/Base.astro';
import { getEntry } from 'astro:content';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import BlocksRenderer from '../../components/BlocksRenderer.astro';
import ContactPage from '../../components/islands/ContactPage.astro';
import { getContact, getTinaRuntimeEnv, pageRelativePath } from '../../lib/tina-data';
import { createIslands } from '../../lib/tina-islands';

const { lang } = Astro.params;

const page = await getEntry('pages', `${lang}/contact`);

if (!page) {
  return Astro.redirect('/404');
}

const { title, description, blocks } = page.data as {
  title: string;
  description: string;
  blocks?: any[];
};

const tinaEnv = getTinaRuntimeEnv(Astro.locals);

const relativePath = pageRelativePath(lang, 'contact.json');
const tinaContact = await getContact(relativePath, tinaEnv);

const tinaContactData = tinaContact.data.contact;
const islands = createIslands(tinaEnv);
---

<Base title={title} description={description} lang={lang!} schema="LocalBusiness" headerStyle="default">
  {tinaEnv ? (
    <TinaIsland name="contact" wrapper={islands.contact.wrapper} params={{ relativePath, lang: lang! }} primary>
      <ContactPage data={tinaContactData} />
    </TinaIsland>
  ) : (
    <main class="min-h-screen">
      {blocks && blocks.map((block: any, index: number) => (
        <BlocksRenderer block={block} index={index} parentData={page.data} />
      ))}
    </main>
  )}
</Base>
