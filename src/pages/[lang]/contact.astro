---
// src/pages/[lang]/contact.astro
import Base from '../../layouts/Base.astro';
import ContactForm from '../../components/ContactForm.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import { getSiteConfig } from '../../utils/site-config';
import { getEntry } from 'astro:content';

const { lang } = Astro.params;
const site = await getSiteConfig();

const page = await getEntry('pages', `${lang}/contact`);

if (!page) {
  return Astro.redirect('/404');
}

const { title, description, heading, subheading } = page.data as {
  title: string;
  description: string;
  heading: string;
  subheading: string;
};
---

<Base title={title} description={description} lang={lang as string}>
  <main class="min-h-screen">
    <!-- Hero Banner -->
    <section class="relative w-full">
      <div class="max-w-6xl mx-auto px-4">
        <div class="relative aspect-[16/7] overflow-hidden">
          <OptimizedImage
            src="/images/contact/senshac-contact-banner.webp"
            alt=""
            class="w-full h-full object-cover"
            loading="eager"
            sizes="(min-width: 768px) 1152px, 100vw"
          />
          <!-- White symbol overlay -->
          <div class="absolute inset-0 flex items-center justify-center">
            <img
              src={site.branding.symbolWhite}
              alt=""
              class="w-24 md:w-32 h-auto"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-16">
          <!-- Contact Info -->
          <div>
            <h1 class="text-sm uppercase tracking-wider text-gray-500 mb-6">{heading}</h1>
            <p class="text-4xl md:text-5xl font-bold mb-8">{subheading}</p>

            <div class="space-y-2 mb-8">
              <a
                href={`mailto:${site.contact.email}`}
                class="block text-lg hover:text-gray-600 transition-colors"
              >
                {site.contact.email}
              </a>
              <a
                href={`tel:${site.contact.phoneLink || site.contact.phone.replace(/\s/g, '')}`}
                class="block text-lg hover:text-gray-600 transition-colors"
              >
                {site.contact.phone}
              </a>
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <ContactForm lang={lang as string} />
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
