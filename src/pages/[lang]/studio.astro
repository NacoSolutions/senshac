---
import { getEntry } from "astro:content";
import TinaIsland from "@tinacms/astro/TinaIsland.astro";
import BlocksRenderer from "../../components/BlocksRenderer.astro";
import AboutPage from "../../components/islands/AboutPage.astro";
// src/pages/[lang]/studio.astro
import Base from "../../layouts/Base.astro";
import {
	getAbout,
	getTinaRuntimeEnv,
	pageRelativePath,
} from "../../lib/tina-data";
import { createIslands } from "../../lib/tina-islands";

const { lang } = Astro.params;

const page = await getEntry("pages", `${lang}/about`);

if (!page) {
	return Astro.redirect("/404");
}

const { title, description, blocks } = page.data as {
	title: string;
	description: string;
	blocks?: any[];
};

const tinaEnv = getTinaRuntimeEnv(Astro.locals);
const islands = createIslands(tinaEnv);
const relativePath = pageRelativePath(lang, "about.json");
const tinaAbout = await getAbout(relativePath, tinaEnv);
const tinaAboutData = tinaAbout.data.about;
---

<Base title={title} description={description} lang={lang} schema="LocalBusiness">
  {tinaAboutData ? (
    <TinaIsland name="about" wrapper={islands.about.wrapper} params={{ relativePath }} primary>
      <AboutPage data={tinaAboutData} />
    </TinaIsland>
  ) : (
    <main class="min-h-screen pt-24 pb-16">
      {blocks && blocks.map((block: any, index: number) => (
        <BlocksRenderer block={block} index={index} parentData={page.data} />
      ))}
    </main>
  )}
</Base>
