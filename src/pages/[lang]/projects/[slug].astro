---
// src/pages/[lang]/projects/[slug].astro
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { processContent } from '../../../utils/shortcodes';

const { lang, slug } = Astro.params;

const projects = await getCollection('projects');
const project = projects.find(p => p.id === `${lang}/${slug}`);

if (!project) {
  return Astro.redirect('/404');
}

const { data } = project;
const html = processContent(project.body || '');
---

<Base title={data.title} description={data.description} lang={lang} headerStyle="transparent">
  <main class="min-h-screen">
    <Fragment set:html={html} />
  </main>
</Base>
