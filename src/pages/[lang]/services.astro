---
// src/pages/[lang]/services.astro
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { processContent } from '../../utils/shortcodes';

const { lang } = Astro.params;

const pages = await getCollection('pages');
const page = pages.find(p => p.id === `${lang}/services`);

if (!page) {
  return Astro.redirect('/404');
}

const html = processContent(page.body || '');
---

<Base title={page.data.title} description={page.data.description} lang={lang}>
  <main class="min-h-screen">
    <Fragment set:html={html} />
  </main>
</Base>
