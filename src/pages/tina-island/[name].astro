---
export const partial = true;

import { PREVIEW_CONTENT_TYPE } from '@tinacms/bridge/preview';
import { getTinaRuntimeEnv } from '../../lib/tina-data';
import { createIslands } from '../../lib/tina-islands';

if (Astro.request.method !== 'POST') {
  return new Response('Method Not Allowed', { status: 405 });
}
const contentType = Astro.request.headers.get('content-type') ?? '';
if (!contentType.includes(PREVIEW_CONTENT_TYPE)) {
  return new Response('Not Found', { status: 404 });
}

const name = Astro.params.name ?? '';
const url = new URL(Astro.request.url);

const tinaEnv = getTinaRuntimeEnv(Astro.locals);
const islands = createIslands(tinaEnv);
const island = islands[name];

if (!island) {
  return new Response(`Unknown island "${name}"`, { status: 404 });
}

// TinaCMS passes the updated data as an envelope keyed by query id: { "hash": { home: { ... } } }
const envelope = await Astro.request.json();
const payloadData = Object.values(envelope)[0];

if (!payloadData) {
  return new Response('Island render failed: empty envelope', { status: 400 });
}

// We mock the QueryResult so `propsFromData` can extract the exact property it needs.
const mockQueryResult = { data: payloadData };
const resolvedProps = island.propsFromData(mockQueryResult, url.searchParams);

// Helper to escape attributes for safety
function escapeAttr(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

const marker = escapeAttr(`${url.pathname}${url.search}`);
const Component = island.component;
const className = island.wrapper.className;
---

{island.wrapper.tag === 'main' ? (
  <main class={className} data-tina-island={marker}>
    <Component {...resolvedProps} />
  </main>
) : (
  <div class={className} data-tina-island={marker}>
    <Component {...resolvedProps} />
  </div>
)}
