# Copy to .env.local for local development. Keep real secrets out of git.

# Tina Cloud
TINA_CLIENT_ID=00000000-0000-0000-0000-000000000000
TINA_TOKEN=replace-with-tina-content-readonly-token
TINA_SEARCH_TOKEN=replace-with-tina-search-token
TINA_BRANCH=main

# Astro/Tina build stability
NODE_OPTIONS=--max-old-space-size=4096

# Contact form and anti-spam
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
RESEND_API_KEY=replace-with-resend-api-key
CONTACT_EMAIL=info@senshac.com
