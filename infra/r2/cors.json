{
	"rules": [
		{
			"allowed": {
				"origins": [
					"https://senshac.com",
					"https://www.senshac.com",
					"https://preview.senshac.com",
					"http://localhost:4321",
					"http://localhost:4001"
				],
				"methods": ["GET", "HEAD"],
				"headers": ["*"]
			},
			"exposeHeaders": [
				"ETag",
				"Content-Length",
				"Content-Range",
				"Accept-Ranges"
			],
			"maxAgeSeconds": 86400
		}
	]
}
